# AlphaForge — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it contains secrets

# ── App ───────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_RUN_openssl_rand_-hex_32
ADMIN_EMAIL=your@email.com

# ── Groww API ─────────────────────────────────────────────────────
# Get from: https://groww.in/trade-api/api-keys
# IMPORTANT: Generate a NEW key. Revoke any previously exposed keys immediately.
#
# Choose one authentication method:
# Option A: TOTP (recommended — no daily expiry)
GROWW_AUTH_FLOW=totp
GROWW_API_KEY=YOUR_TOTP_TOKEN_HERE
GROWW_TOTP_SECRET=YOUR_TOTP_SECRET_HERE
#
# Option B: API Key + Secret (requires daily approval)
# GROWW_AUTH_FLOW=apikey
# GROWW_API_KEY=YOUR_API_KEY_HERE
# GROWW_API_SECRET=YOUR_API_SECRET_HERE

# ── Database (PostgreSQL) ─────────────────────────────────────────
# Self-hosted VPS:
DATABASE_URL=postgresql://alphaforge:STRONG_PASSWORD@localhost:5432/alphaforge
# Supabase (alternative):
# DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── CORS — your production domain ─────────────────────────────────
ALLOWED_ORIGINS=["https://alphaforge.in","https://www.alphaforge.in","http://localhost:5173"]

# ── Community Settings ─────────────────────────────────────────────
MAX_USERS=100
INVITE_ONLY=true
